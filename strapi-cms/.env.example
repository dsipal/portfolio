# strapi-cms/.env is a symlink to the root ../.env
# All environment variables are defined in one place: the project root .env
#
# To set up: ln -sf ../.env .env
#
# Strapi reads these vars directly (names match what config/ files expect):
#
# HOST=0.0.0.0
# PORT=1337
# APP_KEYS=key1,key2,key3,key4
# ADMIN_JWT_SECRET=changeme
# API_TOKEN_SALT=changeme
# TRANSFER_TOKEN_SALT=changeme
# USERS_PERMISSIONS_JWT_SECRET=changeme
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=strapi
# POSTGRES_USER=strapi
# POSTGRES_PASSWORD=changeme
#
# Production only (media uploads via Cloudinary):
# CLOUDINARY_NAME=
# CLOUDINARY_KEY=
# CLOUDINARY_SECRET=
