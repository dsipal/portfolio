# Traefik
TRAEFIK_NETWORK=traefik
TRAEFIK_CERT_RESOLVER=letsencrypt

# Domains
PORTFOLIO_DOMAIN=devinsipal.com
STRAPI_DOMAIN=admin.devinsipal.com

# Postgres
POSTGRES_DB=strapi
POSTGRES_USER=strapi
POSTGRES_PASSWORD=changeme

# Strapi secrets — generate each with: openssl rand -base64 32
# APP_KEYS must be a comma-separated list of 4 values
STRAPI_APP_KEYS=key1,key2,key3,key4
STRAPI_ADMIN_JWT_SECRET=changeme
STRAPI_API_TOKEN_SALT=changeme
STRAPI_TRANSFER_TOKEN_SALT=changeme

# Cloudinary (production media uploads)
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# Strapi API token (create in Strapi Admin → Settings → API Tokens)
STRAPI_API_TOKEN=

# Analytics
GA_TRACKING_ID=
