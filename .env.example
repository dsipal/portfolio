# Traefik
TRAEFIK_NETWORK=traefik
TRAEFIK_CERT_RESOLVER=letsencrypt

# Domains
PORTFOLIO_DOMAIN=devinsipal.com
STRAPI_DOMAIN=admin.devinsipal.com

# Postgres
POSTGRES_DB=strapi
POSTGRES_USER=strapi
POSTGRES_PASSWORD=changeme

# Strapi secrets — generate each with: openssl rand -base64 32
# APP_KEYS must be a comma-separated list of 4 values
APP_KEYS=key1,key2,key3,key4
ADMIN_JWT_SECRET=changeme
API_TOKEN_SALT=changeme
TRANSFER_TOKEN_SALT=changeme
USERS_PERMISSIONS_JWT_SECRET=changeme

# Database URL used when running strapi-cms standalone (outside Docker)
# In Docker, docker-compose constructs this from POSTGRES_* vars above
DATABASE_URL=postgresql://strapi:changeme@localhost:5432/strapi

# Cloudinary (production media uploads)
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# Strapi API token (create in Strapi Admin → Settings → API Tokens)
# Required both at build time (for next build static generation) and runtime
STRAPI_API_TOKEN=

# Analytics (baked in at build time via NEXT_PUBLIC_ prefix)
GA_TRACKING_ID=
